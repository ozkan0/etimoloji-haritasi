# Normalize all text files to LF in the repo and working tree.
# Prevents CRLF<->LF churn when the project is edited across OSes (Windows/macOS/Linux).
* text=auto eol=lf

# Keep binary assets untouched (no line-ending conversion).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
