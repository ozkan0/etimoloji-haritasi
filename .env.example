# Copy this file to .env.local and fill in your own values.
# Variables with the NEXT_PUBLIC_ prefix are exposed to the browser.

# Site URL — local: http://localhost:3000 ; production: your domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini — secret, never use the NEXT_PUBLIC_ prefix here
GEMINI_API_KEY=your-gemini-api-key

# Jawg Maps tile token (public)
NEXT_PUBLIC_JAWG_TOKEN=your-jawg-access-token
